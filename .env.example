# =============================================================================
# Environment Configuration for RentalCore & WarehouseCore Docker Stack
# =============================================================================
# Copy this file to .env and adjust the values for your deployment
# 
# QUICK START:
#   1. cp .env.example .env
#   2. (Optional) Edit .env to change passwords for production
#   3. docker compose up -d
#   4. Wait 1-2 minutes for database initialization
#   5. Access: http://localhost:8081 (RentalCore) / http://localhost:8082 (WarehouseCore)
#   6. Login: admin / admin (you will be forced to change password on first login)
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# The included PostgreSQL container uses these credentials.
# IMPORTANT: Change these passwords in production!

POSTGRES_DB=rentalcore
POSTGRES_USER=rentalcore
POSTGRES_PASSWORD=rentalcore123

# =============================================================================
# CROSS-NAVIGATION DOMAINS
# =============================================================================
# Set these to the actual DOMAINS (without protocol or port!) where your 
# services will be accessible. The apps will automatically use the current 
# protocol (http/https).
#
# PRODUCTION EXAMPLE (with reverse proxy):
#   RENTALCORE_DOMAIN=rent.example.com
#   WAREHOUSECORE_DOMAIN=warehouse.example.com
#   COOKIE_DOMAIN=.example.com
#
# LOCAL DEVELOPMENT:
#   Leave empty - apps will auto-detect and use localhost:8081 / localhost:8082

RENTALCORE_DOMAIN=
WAREHOUSECORE_DOMAIN=

# =============================================================================
# SSO COOKIE DOMAIN
# =============================================================================
# Set this to enable Single Sign-On between RentalCore and WarehouseCore.
# Must start with a DOT for subdomain sharing (e.g., .example.com)
#
# IMPORTANT: Leave EMPTY for localhost development or local IP access!
# Setting a domain here while accessing via localhost will cause an endless login loop.

COOKIE_DOMAIN=

# =============================================================================
# LED MQTT CONFIGURATION (WarehouseCore)
# =============================================================================
# Self-hosted Mosquitto MQTT broker for LED warehouse bin highlighting.
# The password file is automatically generated from these credentials.
# 
# To change: Edit these values and restart with `docker compose restart mosquitto`

LED_MQTT_HOST=mosquitto
LED_MQTT_PORT=1883
LED_MQTT_TLS=false
LED_MQTT_USER=leduser
LED_MQTT_PASS=ledpassword123
LED_MQTT_TOPIC_PREFIX=weidelbach
LED_WAREHOUSE_ID=weidelbach
LED_MQTT_CONNECT_RETRIES=10
LED_MQTT_CONNECT_RETRY_DELAY_MS=2000

# Auto-admin assignment: users matching this name get admin role automatically
ADMIN_NAME_MATCH=

# =============================================================================
# NEXTCLOUD FILE POOL (Optional)
# =============================================================================
# Enable synchronization with a Nextcloud WebDAV file pool.
# Leave empty to disable Nextcloud integration.

# NEXTCLOUD_WEBDAV_URL=https://cloud.example.com/remote.php/dav/files/username
# NEXTCLOUD_WEBDAV_USER=your-nextcloud-user
# NEXTCLOUD_WEBDAV_PASSWORD=nextcloud-app-password
# NEXTCLOUD_WEBDAV_BASE_PATH=rentalcore-filepool

# Set to false to skip automatic backfill of existing files on startup
# NEXTCLOUD_BACKFILL_ON_START=true

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# The db-backup service automatically backs up PostgreSQL daily.

BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_HOURS=24

# =============================================================================
# NOTES
# =============================================================================
# - Default admin login: admin / admin (forced to change password on first login)
# - If domains are empty, apps auto-detect based on the current URL
# - Do NOT include protocol (http:// or https://) - it's added automatically
# - For subdomain SSO: COOKIE_DOMAIN must start with a dot (.example.com)
# - MQTT credentials must match ESP32 secrets.h for LED control
# 
# For cloud MQTT broker (EMQX, HiveMQ, etc.), configure:
#   LED_MQTT_HOST=your-broker.emqxsl.com
#   LED_MQTT_PORT=8883
#   LED_MQTT_TLS=true
# =============================================================================
